  "firestore": {
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Customer records"
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Invoice records"
    },
    "/invoice_items/{itemId}": {
      "schema": "InvoiceItem",
      "description": "Individual items/devices in invoices"
    },
    "/inventory_items/{itemId}": {
      "schema": "InventoryItem",
      "description": "Inventory items records"
    },
    "/currencies/{currencyId}": {
      "schema": "Currency",
      "description": "Supported currencies"
    },
    "/device_types/{typeId}": {
      "schema": "DeviceType",
      "description": "Supported device types"
    },
    "/device_categories/{categoryId}": {
      "schema": "DeviceCategory",
      "description": "Device Categories"
    },
    "/device_models/{modelId}": {
      "schema": "DeviceModel",
      "description": "Device Models"
    },
    "/settings/app": {
      "schema": "Settings",
      "description": "App-wide settings"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "System users"
    },
    "/settings/shop": {
      "schema": "ShopConfig",
      "description": "Shop configuration"
    },
    "/vault_transactions/{transactionId}": {
      "schema": "VaultTransaction",
      "description": "Records of the safe/vault activity"
    },
    "/company_details/{docId}": {
      "schema": "CompanyDetails",
      "description": "Company details information"
    },
    "/approval_actions/{docId}": {
      "schema": "ApprovalAction",
      "description": "Approval actions for maintenance items"
    },
    "/maintenance_actions/{actionId}": {
      "schema": "MaintenanceAction",
      "description": "Maintenance action logs"
    },
    "/engineers/{engineerId}": {
      "schema": "Engineer",
      "description": "Engineer records"
    },
    "/user_devices/{deviceId}": {
      "schema": "UserDevice",
      "description": "System user devices"
    },
    "/document_outputs/{id}": {
      "schema": "DocumentOutput",
      "description": "Printed document outputs"
    }
